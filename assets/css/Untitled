/* hyperlinks list styling for external CSS file */

ul {
  list-style: none; /* bullets silinir */
  padding: 0;       /* default padding silinir */
  margin: 0;        /* default margin silinir */
}

ul li {
  margin: 10px 0;   /* elementlər arası boşluq */
}

ul li a {
  text-decoration: none;       /* underline yox */
  color: #1a73e8;              /* əsas link rəngi */
  font-weight: 500;            /* bir az qalın */
  font-family: Arial, sans-serif;
  padding: 6px 10px;           /* klikləmə üçün sahə */
  border-radius: 4px;          /* kənarları yumşaldır */
  display: inline-block;       /* padding tətbiq olunur */
  transition: all 0.3s ease;   /* hover üçün yumşaq keçid */
}

ul li a:hover {
  background-color: #e0f0ff;   /* hover zamanı açıq mavi */
  color: #0b49c1;              /* hover zamanı qaranlıq mavi */
  transform: translateX(3px);  /* hover zamanı yüngül sağa hərəkət */
}